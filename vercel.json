{
  "buildCommand": "cd skill-gap-agent/frontend && npm install && npm run build",
  "outputDirectory": "skill-gap-agent/frontend/dist",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
